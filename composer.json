{
    "name": "digitickets/jwt",
    "description": "Provides classes for creating and parsing JWTs.",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "DigiTickets\\Jwt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DigiTickets\\JwtTests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Anthony Kuske",
            "email": "anthony.kuske@digitickets.co.uk"
        }
    ],
    "require": {
        "php": ">=7.3",
        "firebase/php-jwt": "^6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6 || ^10.0 || ^11.0"
    },
    "scripts": {
        "test": "./vendor/bin/phpunit tests"
    }
}
